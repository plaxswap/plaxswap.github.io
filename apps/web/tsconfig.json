{
  "extends": "tsconfig/nextjs.json",
  "compilerOptions": {
    "baseUrl": "src",
    "strictNullChecks": false,
    "noImplicitAny": false,
    "noFallthroughCasesInSwitch": true,
    "downlevelIteration": true,
    "moduleResolution": "node",
    "skipLibCheck": true,
    "target": "es2020"
  },
  "exclude": [
    "node_modules",
    "src/utils/safeConnector.ts"
  ],
  "include": [
    "next-env.d.ts",
    "./src/types/**/*.d.ts",
    "./src/**/*.ts",
    "./src/**/*.tsx"
  ]
}
